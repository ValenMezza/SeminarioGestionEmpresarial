<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clientes</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/sidebar.ejs') %>
    <main id="clientes-page">

        <div class="page-header">
            <h1 class="page-title">Clientes</h1>
            <a href="/clientes/nuevo_cliente" class="btn-primary">+ Nuevo cliente</a>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#ID</th>
                        <th>Nombre</th>
                        <th>Teléfono</th>
                        <th>Email</th>
                        <th>Dirección</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (clientes.length === 0) { %>
                        <tr>
                            <td colspan="6" style="text-align:center; color:#94a3b8; padding: 2rem;">
                                No hay clientes registrados
                            </td>
                        </tr>
                    <% } %>
                    <% clientes.forEach(c => { %>
                        <tr>
                            <td>#<%= c.id %></td>
                            <td><%= c.nombre %></td>
                            <td><%= c.telefono || '—' %></td>
                            <td><%= c.email || '—' %></td>
                            <td><%= c.direccion || '—' %></td>
                            <td>
                                <a href="/clientes/detalle/<%= c.id %>" class="btn-secondary">Ver detalle</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

    </main>
    <script src="/javascript/sidebar.js"></script>
</body>
</html>
