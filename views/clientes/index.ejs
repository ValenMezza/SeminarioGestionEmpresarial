<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Clientes</title>
    <link rel="icon" type="image/jpeg" href="/img/suelosurjpg.jpg">
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <%- include('../partials/sidebar.ejs') %>
        <main id="clientes-page">

            <div class="page-header">
                <h1 class="page-title">Clientes</h1>
                <div class="page-header-actions">
                    <a href="/clientes/cuentas" class="btn-secondary">Cuentas corrientes</a>
                    <a href="/clientes/nuevo_cliente" class="btn-primary-green">+ Nuevo cliente</a>
                </div>
            </div>

            <!-- Filtros de busqueda -->
            <form method="GET" action="/clientes" class="filtros-bar">
                <div class="filtro-group">
                    <label name="id">ID</label>
                    <input type="text" name="id" value="<%= filtros.id %>" placeholder="Buscar por ID...">

                </div>
                <div class="filtro-group">
                    <label>Nombre / Apellido</label>
                    <input type="text" name="nombre" value="<%= filtros.nombre %>" placeholder="Buscar por nombre...">
                </div>
                <div class="filtro-group">
                    <label>DNI</label>
                    <input type="text" name="dni" value="<%= filtros.dni %>" placeholder="Buscar por DNI...">
                </div>
                <button type="submit" class="btn-primary">Buscar</button>
                <% if (filtros.id || filtros.nombre || filtros.dni) { %>
                    <a href="/clientes" class="btn-secondary">Limpiar</a>
                <% } %>
            </form>

            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#ID</th>
                            <th>Nombre</th>
                            <th>Apellido</th>
                            <th>DNI</th>
                            <th>Telefono</th>
                            <th>Cuenta corriente</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (clientes.length===0) { %>
                            <tr>
                                <td colspan="8" class="td-vacia">No se encontraron clientes</td>
                            </tr>
                        <% } %>
                        <% clientes.forEach(c => { %>
                            <tr>
                                <td>#<%= c.id %></td>
                                <td><%= c.nombre %></td>
                                <td><%= c.apellido || '—' %></td>
                                <td><%= c.dni || '—' %></td>
                                <td><%= c.telefono || '—' %></td>
                                <td>
                                    <% if (c.cuentaCorriente) { %>
                                        <span class="badge badge--con-stock">Habilitada</span>
                                    <% } else { %>
                                        <span class="badge badge--sin-stock">No</span>
                                    <% } %>
                                </td>
                                <td>
                                    <div style="display:flex; gap:0.4rem">
                                        <a href="/clientes/detalle/<%= c.id %>" class="btn-secondary btn-sm">Ver</a>
                                        <a href="/clientes/editar/<%= c.id %>" class="btn-secondary-yellow btn-sm">Editar</a>
                                        <form action="/clientes/eliminar/<%= c.id %>" method="POST"
                                            onsubmit="return confirm('¿Eliminar a <%= c.nombre %> <%= c.apellido %>?')">
                                            <button type="submit" class="btn-danger btn-sm">Eliminar</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

        </main>
        <%- include('../partials/scripts.ejs') %>
</body>

</html>
