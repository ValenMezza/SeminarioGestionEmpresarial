<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nuevo cliente</title>
    <link rel="icon" type="image/jpeg" href="/img/suelosurjpg.jpg">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/sidebar.ejs') %>
    <main id="clientes-nuevo">

        <div class="page-header">
            <div>
                <a href="/clientes" class="back-link">← Clientes</a>
                <h1 class="page-title">Nuevo cliente</h1>
            </div>
        </div>

        <div class="form-card">
            <form action="/clientes/nuevo_cliente" method="POST" class="form-grid" id="formNuevoCliente">

                <div class="form-row-2">
                    <div class="form-group">
                        <label for="nombre">Nombre *</label>
                        <input type="text" name="nombre" id="nombre" placeholder="Ej: Juan" required>
                    </div>
                    <div class="form-group">
                        <label for="apellido">Apellido *</label>
                        <input type="text" name="apellido" id="apellido" placeholder="Ej: Perez" required>
                    </div>
                </div>

                <div class="form-row-2">
                    <div class="form-group">
                        <label for="telefono">Telefono *</label>
                        <input type="text" name="telefono" id="telefono" placeholder="Ej: 351 000 0000" required>
                    </div>
                    <div class="form-group">
                        <label for="dni">DNI (opcional)</label>
                        <input type="text" name="dni" id="dni" placeholder="Ej: 30000000">
                    </div>
                </div>

                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" name="email" id="email" placeholder="Ej: juan@email.com">
                </div>

                <div class="form-group">
                    <label for="direccion">Direccion</label>
                    <input type="text" name="direccion" id="direccion" placeholder="Ej: Av. Siempre Viva 123">
                </div>

                <div class="form-group form-group--checkbox">
                    <label class="checkbox-label">
                        <input type="checkbox" name="cuentaCorriente" value="true" id="cuentaCorriente">
                        <span>Habilitar cuenta corriente</span>
                    </label>
                    <span class="form-hint">Permite registrar saldo y movimientos para este cliente</span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary">Guardar</button>
                    <a href="/clientes" class="btn-secondary">Cancelar</a>
                </div>

            </form>
        </div>

    </main>
    <%- include('../partials/scripts.ejs') %>
    <script>
        document.getElementById('formNuevoCliente').addEventListener('submit', function(e) {
            if (!validarFormulario(this, ['#nombre', '#apellido', '#telefono'])) {
                e.preventDefault();
            }
        });
    </script>
</body>
</html>
