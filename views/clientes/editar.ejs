<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar cliente</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/sidebar.ejs') %>
    <main id="clientes-nuevo">

        <div class="page-header">
            <div>
                <a href="/clientes/detalle/<%= cliente.id %>" class="back-link">← <%= cliente.nombre %></a>
                <h1 class="page-title">Editar cliente</h1>
            </div>
        </div>

        <div class="form-card">
            <% if (error) { %><p style="color:red"><%= error %></p><% } %>
            <form action="/clientes/editar/<%= cliente.id %>" method="POST" class="form-grid">

                <div class="form-group">
                    <label for="nombre">Nombre completo</label>
                    <input type="text" name="nombre" id="nombre" value="<%= cliente.nombre %>" required>
                </div>

                <div class="form-group">
                    <label for="telefono">Teléfono</label>
                    <input type="text" name="telefono" id="telefono" value="<%= cliente.telefono || '' %>">
                </div>

                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" name="email" id="email" value="<%= cliente.email || '' %>">
                </div>

                <div class="form-group">
                    <label for="direccion">Dirección</label>
                    <input type="text" name="direccion" id="direccion" value="<%= cliente.direccion || '' %>">
                </div>

                <div class="form-group form-group--checkbox">
                    <label class="checkbox-label">
                        <input type="checkbox" name="cuentaCorriente" value="true" id="cuentaCorriente" <%= cliente.cuentaCorriente ? 'checked' : '' %>>
                        <span>Habilitar cuenta corriente</span>
                    </label>
                    <span class="form-hint">Permite registrar saldo y movimientos para este cliente</span>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary">Guardar</button>
                    <a href="/clientes/detalle/<%= cliente.id %>" class="btn-secondary">Cancelar</a>
                </div>

            </form>
        </div>

    </main>
    <script src="/javascript/sidebar.js"></script>
</body>
</html>
