<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Venta en Cantera</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include("../partials/sidebar.ejs") %>

    <main id="ventas" class="ventas-layout">

        <!-- Productos -->
        <section class="ventas-productos">
            <div class="ventas-productos__header">
                <div>
                    <a href="/ventas" class="back-link">← Ventas</a>
                    <h2 class="ventas-productos__title">Venta en Cantera</h2>
                </div>
            </div>
            <ul class="ventas-lista-productos">
                <% productos.forEach(p => { %>
                    <li>
                        <div class="ventas-card <%= p.stock === 0 ? 'ventas-card--sin-stock' : '' %>">
                            <div class="ventas-card__top">
                                <span class="ventas-card__nombre"><%= p.producto %></span>
                                <span class="badge badge--<%= p.stock > 0 ? 'con-stock' : 'sin-stock' %>">
                                    <%= p.stock > 0 ? p.stock + ' unid.' : 'Sin stock' %>
                                </span>
                            </div>
                            <div class="ventas-card__precio">$<%= p.precio.toLocaleString('es-AR') %></div>
                            <button
                                class="addToCart btn-primary"
                                data-id="<%= p.id %>"
                                data-nombre="<%= p.producto %>"
                                data-precio="<%= p.precio %>"
                                <%= p.stock === 0 ? 'disabled' : '' %>
                            >
                                <%= p.stock === 0 ? 'Sin stock' : '+ Agregar' %>
                            </button>
                        </div>
                    </li>
                <% }) %>
            </ul>
        </section>

        <!-- Carrito -->
        <aside id="carrito" class="carrito-aside">
            <h3 class="carrito-title">Carrito</h3>
            <div id="cartItemsContainer"></div>
            <div id="cartTotal" class="cart-total-bar" style="display:none">
                <span>Total</span>
                <span id="cartTotalValor"></span>
            </div>

            <!-- Precio editable -->
            <div id="precioEditableSection" class="precio-editable-section" style="display:none">
                <label class="toggle-row">
                    <input type="checkbox" id="checkPrecioEditable">
                    <span>Modificar precio total</span>
                </label>
                <input type="number" id="precioEditableInput" class="input-sm" style="display:none" min="0" step="100">
            </div>

            <!-- Cliente -->
            <div id="seccionCliente" style="display:none">
                <div class="carrito-seccion">
                    <label class="toggle-row">
                        <input type="checkbox" id="checkParticular">
                        <span>Cliente particular (sin datos)</span>
                    </label>
                </div>
                <div id="busquedaClienteWrapper">
                    <%- include("../partials/buscar_cliente.ejs") %>
                </div>

                <%- include("../partials/metodo_pago.ejs") %>
            </div>

            <!-- Acciones -->
            <div id="cartActions" class="cart-actions" style="display:none">
                <button type="button" id="btnConfirmarCantera" class="btn-finalizar" disabled>Confirmar venta</button>
                <button type="button" id="btnLimpiarCarrito" class="btn-secondary">Limpiar carrito</button>
            </div>
        </aside>

    </main>

    <!-- Form oculto para submit -->
    <form id="formCantera" action="/ventas/finalizar-cantera" method="POST" style="display:none">
        <input type="hidden" name="clienteId" id="formClienteId">
        <input type="hidden" name="clienteNombre" id="formClienteNombre">
        <input type="hidden" name="items" id="formItems">
        <input type="hidden" name="metodoPago" id="formMetodoPago">
        <input type="hidden" name="precioTotal" id="formPrecioTotal">
    </form>

    <script src="/javascript/formValidation.js"></script>
    <script src="/javascript/buscarCliente.js"></script>
    <script src="/javascript/ventasCantera.js"></script>
    <script src="/javascript/sidebar.js"></script>
</body>
</html>
