<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Venta confirmada</title>
    <link rel="icon" type="image/jpeg" href="/img/suelosurjpg.jpg">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include("../partials/sidebar.ejs") %>

    <main id="confirmacion-page">

        <div class="confirmacion-card">
            <div class="confirmacion-icon">&#10003;</div>
            <h1 class="confirmacion-titulo">Venta confirmada</h1>
            <div class="confirmacion-detalles">
                <div class="info-row">
                    <span class="info-label">Tipo</span>
                    <span class="info-value"><%= tipo === 'cantera' ? 'Venta en Cantera' : 'Venta con Viaje' %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Cliente</span>
                    <span class="info-value"><%= cliente %></span>
                </div>
                <div class="info-row">
                    <span class="info-label">Total</span>
                    <span class="info-value detalle-precio">$<%= Number(total).toLocaleString('es-AR') %></span>
                </div>
            </div>
            <div class="confirmacion-acciones">
                <a href="/ventas/cantera" class="btn-primary">Nueva venta</a>
                <a href="/ventas" class="btn-secondary">Volver a ventas</a>
            </div>
        </div>

    </main>
    <%- include('../partials/scripts.ejs') %>
</body>
</html>
