<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gestión Empresarial — Acceso</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <div id="login-page">
        <div class="login-card">

            <div class="login-header">
                <div class="login-logo">
                    <img src="/img/suelosurjpg.jpg" alt="Logo">
                </div>
                <h1 class="login-title">Suelo Sur SAS</h1>
                <p class="login-subtitle">Ingresá con tu cuenta para continuar</p>
            </div>

            <% if (error) { %>
            <p class="login-error"><%= error %></p>
            <% } %>

            <form class="login-form" action="/login" method="POST">
                <div class="form-group">
                    <label for="user">Usuario</label>
                    <input type="text" id="user" name="user" placeholder="Tu usuario" autocomplete="username" required>
                </div>
                <div class="form-group">
                    <label for="password">Contraseña</label>
                    <input type="password" id="password" name="password" placeholder="Contraseña" autocomplete="current-password" required>
                </div>
                <button type="submit" class="btn-primary">Ingresar</button>
            </form>

        </div>
    </div>
</body>
</html>
