<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuraciones</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/sidebar.ejs') %>
    <main id="config-page">

        <div class="page-header">
            <h1 class="page-title">Configuraciones del sistema</h1>
        </div>

        <div class="config-cards-grid">

            <a href="/configuraciones/usuarios" class="config-card">
                <span class="config-card__icon">👥</span>
                <div class="config-card__body">
                    <h3 class="config-card__title">Usuarios del sistema</h3>
                    <p class="config-card__desc">Crear, pausar, resetear o eliminar usuarios. Administrá roles de Administrador y Operador.</p>
                </div>
                <span class="config-card__arrow">→</span>
            </a>

        </div>

    </main>
    <script src="/javascript/sidebar.js"></script>
</body>
</html>
