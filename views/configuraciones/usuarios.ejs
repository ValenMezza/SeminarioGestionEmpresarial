<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Usuarios</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/sidebar.ejs') %>
    <main id="config-page">

        <div class="page-header">
            <div>
                <a href="/configuraciones" class="back-link">← Configuraciones</a>
                <h1 class="page-title">Usuarios del sistema</h1>
            </div>
            <button type="button" class="btn-primary-green" id="btnNuevoUsuario">+ Nuevo usuario</button>
        </div>

        <!-- Toggle filtro -->
        <div class="filtros-bar" style="margin-bottom:1rem">
            <label class="toggle-row">
                <input type="checkbox" id="toggleMostrarPausados" checked>
                <span>Mostrar usuarios pausados</span>
            </label>
        </div>

        <!-- Tabla de usuarios -->
        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#ID</th>
                        <th>Nombre</th>
                        <th>Apellido</th>
                        <th>Usuario</th>
                        <th>Rol</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody id="tablaUsuarios">
                    <% if (usuarios.length === 0) { %>
                        <tr>
                            <td colspan="7" class="td-vacia">No hay usuarios registrados</td>
                        </tr>
                    <% } %>
                    <% usuarios.forEach(u => { %>
                        <tr data-activo="<%= u.activo %>">
                            <td>#<%= u.id %></td>
                            <td><%= u.nombre || '—' %></td>
                            <td><%= u.apellido || '—' %></td>
                            <td><b><%= u.user %></b></td>
                            <td>
                                <span class="badge badge--rol-<%= u.rol %>">
                                    <%= u.rol === 'admin' ? 'Administrador' : 'Operador' %>
                                </span>
                            </td>
                            <td>
                                <span class="badge badge--<%= u.activo ? 'con-stock' : 'sin-stock' %>">
                                    <%= u.activo ? 'Activo' : 'Pausado' %>
                                </span>
                            </td>
                            <td class="acciones-col">
                                <form action="/configuraciones/usuarios/pausar/<%= u.id %>" method="POST" style="display:inline">
                                    <button type="submit" class="btn-secondary btn-sm">
                                        <%= u.activo ? 'Pausar' : 'Activar' %>
                                    </button>
                                </form>
                                <form action="/configuraciones/usuarios/reset/<%= u.id %>" method="POST" style="display:inline"
                                      onsubmit="return confirm('¿Resetear contraseña de <%= u.user %>? La nueva contraseña sera: 123456')">
                                    <button type="submit" class="btn-primary btn-sm">Resetear pass</button>
                                </form>
                                <% if (u.id !== 1) { %>
                                <form action="/configuraciones/usuarios/eliminar/<%= u.id %>" method="POST" style="display:inline"
                                      onsubmit="return confirm('¿Eliminar usuario <%= u.user %>?')">
                                    <button type="submit" class="btn-danger btn-sm">Eliminar</button>
                                </form>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

    </main>

    <!-- Modal: Crear nuevo usuario -->
    <div id="modal-nuevo-usuario" class="modal-overlay" style="display:none">
        <div class="modal-box">
            <div class="modal-header">
                <h2 class="modal-title">Nuevo usuario</h2>
                <button type="button" class="modal-close" id="cerrarModalUsuario">✕</button>
            </div>

            <form action="/configuraciones/usuarios/crear" method="POST" class="form-grid" id="formNuevoUsuario">
                <div class="form-row-2">
                    <div class="form-group">
                        <label for="nombre">Nombre *</label>
                        <input type="text" name="nombre" id="nombre" placeholder="Ej: Juan" required>
                    </div>
                    <div class="form-group">
                        <label for="apellido">Apellido *</label>
                        <input type="text" name="apellido" id="apellido" placeholder="Ej: Perez" required>
                    </div>
                </div>

                <div class="form-group">
                    <label for="user">Nombre de usuario *</label>
                    <input type="text" name="user" id="user" placeholder="Ej: operador1" required>
                </div>

                <div class="form-group">
                    <label for="password">Contraseña *</label>
                    <input type="password" name="password" id="password" placeholder="Min. 6 caracteres" required>
                </div>

                <div class="form-group">
                    <label for="rol">Rol</label>
                    <select name="rol" id="rol">
                        <option value="operador">Operador</option>
                        <option value="admin">Administrador</option>
                    </select>
                </div>

                <div class="modal-actions">
                    <button type="submit" class="btn-primary">Crear usuario</button>
                    <button type="button" class="btn-secondary" id="cancelarModalUsuario">Cancelar</button>
                </div>
            </form>
        </div>
    </div>

    <script src="/javascript/formValidation.js"></script>
    <script src="/javascript/sidebar.js"></script>
    <script>
        // Modal nuevo usuario
        const modalUsuario = document.getElementById('modal-nuevo-usuario');
        document.getElementById('btnNuevoUsuario').addEventListener('click', () => {
            modalUsuario.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        });
        function cerrarModal() {
            modalUsuario.style.display = 'none';
            document.body.style.overflow = '';
        }
        document.getElementById('cerrarModalUsuario').addEventListener('click', cerrarModal);
        document.getElementById('cancelarModalUsuario').addEventListener('click', cerrarModal);

        // Validacion
        document.getElementById('formNuevoUsuario').addEventListener('submit', function(e) {
            if (!validarFormulario(this, ['#nombre', '#apellido', '#user', '#password'])) {
                e.preventDefault();
            }
        });

        // Toggle pausados
        const toggle = document.getElementById('toggleMostrarPausados');
        toggle.addEventListener('change', () => {
            const filas = document.querySelectorAll('#tablaUsuarios tr[data-activo]');
            filas.forEach(fila => {
                if (fila.dataset.activo === 'false') {
                    fila.style.display = toggle.checked ? '' : 'none';
                }
            });
        });
    </script>
</body>
</html>
