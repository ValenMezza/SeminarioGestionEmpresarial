<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contenedores</title>
    <link rel="icon" type="image/jpeg" href="/img/suelosurjpg.jpg">
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <%- include("../partials/sidebar.ejs") %>
    <main id="contenedores">

        <div class="page-header">
            <h1 class="page-title">Contenedores</h1>
            <div class="page-header-actions">
                <a href="/contenedores/config" class="btn-config">Configurar precios</a>
                <form action="/contenedores/crear" method="POST" style="display:inline">
                    <button type="submit" class="btn-primary-green">+ Nuevo contenedor</button>
                </form>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <span class="stat-label">Total</span>
                <span class="stat-value"><%= contenedores.length %></span>
            </div>
            <div class="stat-card stat-card--disponible">
                <span class="stat-label">Disponibles</span>
                <span class="stat-value"><%= contenedores.filter(c => c.estado === "Disponible").length %></span>
            </div>
            <div class="stat-card stat-card--alquilado">
                <span class="stat-label">Alquilados</span>
                <span class="stat-value"><%= contenedores.filter(c => c.estado === "Alquilado").length %></span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Precio / dia</span>
                <span class="stat-value">$<%= contenedores[0]?.precioDia?.toLocaleString('es-AR') %></span>
            </div>
            <div class="stat-card">
                <span class="stat-label">Precio alquiler</span>
                <span class="stat-value">$<%= contenedores[0]?.precioAlquiler?.toLocaleString('es-AR') %></span>
            </div>
        </div>

        <div class="contenedores-table-wrapper">
            <table class="contenedores-table">
                <thead>
                    <tr>
                        <th>#ID</th>
                        <th>Estado</th>
                        <th>Cliente</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                        <th>Precio alquiler</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% contenedores.forEach(c => { %>
                        <tr>
                            <td>#<%= c.id %></td>
                            <td>
                                <span class="badge badge--<%= c.estado === 'Alquilado' ? 'alquilado' : 'disponible' %>">
                                    <%= c.estado %>
                                </span>
                            </td>
                            <td><%= c.cliente || '—' %></td>
                            <td><%= c.inicioAlquiler ? formatFecha(c.inicioAlquiler) : '—' %></td>
                            <td><%= c.finAlquiler ? formatFecha(c.finAlquiler) : '—' %></td>
                            <td><%= c.estado === 'Alquilado' ? '$' + c.precioAlquiler?.toLocaleString('es-AR') : '—' %></td>
                            <td class="td-acciones">
                                <% if (c.estado === 'Alquilado') { %>
                                    <a href="/contenedores/detalle/<%= c.id %>" class="btn-secondary btn-sm">Detalle</a>
                                    <a href="/contenedores/<%= c.id %>/edit" class="btn-secondary-yellow btn-sm">Editar</a>
                                <% } else { %>
                                    <form action="/contenedores/eliminar/<%= c.id %>" method="POST" style="display:inline"
                                          onsubmit="return confirm('¿Eliminar Contenedor #<%= c.id %>?')">
                                        <button type="submit" class="btn-danger btn-sm">Eliminar</button>
                                    </form>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

    </main>

    <script src="/javascript/sidebar.js"></script>
</body>

</html>
