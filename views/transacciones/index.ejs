<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transacciones</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/sidebar.ejs') %>
    <main id="transacciones-page">

        <div class="page-header">
            <h1 class="page-title">Transacciones</h1>
        </div>

        <!-- Filtros -->
        <form method="GET" action="/transacciones" class="filtros-bar filtros-bar--extended">
            <div class="filtro-group">
                <label>#ID</label>
                <input type="number" name="id" value="<%= filtros.id %>" placeholder="Buscar por ID..." min="1">
            </div>
            <div class="filtro-group">
                <label>Tipo</label>
                <select name="tipo">
                    <option value="todos" <%= filtros.tipo === 'todos' || !filtros.tipo ? 'selected' : '' %>>Todos</option>
                    <% tipos.forEach(t => { %>
                        <option value="<%= t %>" <%= filtros.tipo === t ? 'selected' : '' %>><%= t %></option>
                    <% }) %>
                </select>
            </div>
            <div class="filtro-group">
                <label>Cliente</label>
                <input type="text" name="cliente" value="<%= filtros.cliente %>" placeholder="Nombre del cliente...">
            </div>
            <div class="filtro-group">
                <label>Desde</label>
                <input type="date" name="fechaDesde" value="<%= filtros.fechaDesde %>">
            </div>
            <div class="filtro-group">
                <label>Hasta</label>
                <input type="date" name="fechaHasta" value="<%= filtros.fechaHasta %>">
            </div>
            <div class="filtro-group">
                <label>Monto mín.</label>
                <input type="number" name="montoMin" value="<%= filtros.montoMin %>" placeholder="0" min="0">
            </div>
            <div class="filtro-group">
                <label>Monto máx.</label>
                <input type="number" name="montoMax" value="<%= filtros.montoMax %>" placeholder="Sin límite" min="0">
            </div>
            <button type="submit" class="btn-primary">Filtrar</button>
            <% if (filtros.id || filtros.tipo || filtros.cliente || filtros.fechaDesde || filtros.fechaHasta || filtros.montoMin || filtros.montoMax) { %>
                <a href="/transacciones" class="btn-secondary">Limpiar</a>
            <% } %>
        </form>

        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#ID</th>
                        <th>Tipo</th>
                        <th>Cliente</th>
                        <th>Descripción</th>
                        <th>Fecha</th>
                        <th>Monto</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    <% if (transacciones.length === 0) { %>
                        <tr>
                            <td colspan="7" class="td-vacia">No hay transacciones que coincidan con los filtros</td>
                        </tr>
                    <% } %>
                    <% transacciones.forEach(t => { %>
                        <tr>
                            <td>#<%= t.id %></td>
                            <td>
                                <span class="badge badge--tipo-<%= t.tipo.toLowerCase().replace(/ /g,'-') %>">
                                    <%= t.tipo %>
                                </span>
                            </td>
                            <td><%= t.cliente %></td>
                            <td><%= t.descripcion %></td>
                            <td><%= t.fecha %></td>
                            <td class="transaccion-monto">$<%= t.monto?.toLocaleString('es-AR') %></td>
                            <td>
                                <button type="button" class="btn-secondary btn-sm btn-ver-transaccion"
                                    data-id="<%= t.id %>"
                                    data-tipo="<%= t.tipo %>"
                                    data-cliente="<%= t.cliente %>"
                                    data-descripcion="<%= t.descripcion %>"
                                    data-fecha="<%= t.fecha %>"
                                    data-monto="<%= t.monto %>">
                                    Ver
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

    </main>

    <!-- Modal detalle transaccion -->
    <div id="modal-transaccion" class="modal-overlay" style="display:none">
        <div class="modal-box">
            <div class="modal-header">
                <h2 class="modal-title">Detalle de transacción <span id="modal-t-id"></span></h2>
                <button type="button" class="modal-close" id="cerrarModalTransaccion">✕</button>
            </div>
            <div class="alquiler-resumen__rows" style="margin-top:1rem">
                <div class="alquiler-resumen__row">
                    <span class="alquiler-resumen__label">Tipo</span>
                    <span id="modal-t-tipo"></span>
                </div>
                <div class="alquiler-resumen__row">
                    <span class="alquiler-resumen__label">Cliente</span>
                    <span id="modal-t-cliente"></span>
                </div>
                <div class="alquiler-resumen__row">
                    <span class="alquiler-resumen__label">Descripción</span>
                    <span id="modal-t-descripcion"></span>
                </div>
                <div class="alquiler-resumen__row">
                    <span class="alquiler-resumen__label">Fecha</span>
                    <span id="modal-t-fecha"></span>
                </div>
                <div class="alquiler-resumen__row">
                    <span class="alquiler-resumen__label">Monto</span>
                    <span id="modal-t-monto" style="font-weight:700"></span>
                </div>
            </div>
            <div class="modal-actions" style="margin-top:1.5rem">
                <button type="button" class="btn-secondary" id="cerrarModalTransaccionBtn">Cerrar</button>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('.btn-ver-transaccion').forEach(btn => {
            btn.addEventListener('click', () => {
                document.getElementById('modal-t-id').textContent        = '#' + btn.dataset.id;
                document.getElementById('modal-t-tipo').textContent      = btn.dataset.tipo;
                document.getElementById('modal-t-cliente').textContent   = btn.dataset.cliente;
                document.getElementById('modal-t-descripcion').textContent = btn.dataset.descripcion;
                document.getElementById('modal-t-fecha').textContent     = btn.dataset.fecha;
                document.getElementById('modal-t-monto').textContent     = '$' + Number(btn.dataset.monto).toLocaleString('es-AR');
                document.getElementById('modal-transaccion').style.display = 'flex';
                document.body.style.overflow = 'hidden';
            });
        });
        function cerrarModal() {
            document.getElementById('modal-transaccion').style.display = 'none';
            document.body.style.overflow = '';
        }
        document.getElementById('cerrarModalTransaccion').addEventListener('click', cerrarModal);
        document.getElementById('cerrarModalTransaccionBtn').addEventListener('click', cerrarModal);
        document.getElementById('modal-transaccion').addEventListener('click', e => {
            if (e.target === e.currentTarget) cerrarModal();
        });
    </script>

    <%- include('../partials/scripts.ejs') %>
</body>
</html>
