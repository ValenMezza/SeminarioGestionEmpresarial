<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Transacciones</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/sidebar.ejs') %>
    <main id="transacciones-page">

        <div class="page-header">
            <h1 class="page-title">Transacciones</h1>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#ID</th>
                        <th>Tipo</th>
                        <th>Cliente</th>
                        <th>Descripción</th>
                        <th>Fecha</th>
                        <th>Monto</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (transacciones.length === 0) { %>
                        <tr>
                            <td colspan="6" class="td-vacia">No hay transacciones registradas</td>
                        </tr>
                    <% } %>
                    <% transacciones.slice().reverse().forEach(t => { %>
                        <tr>
                            <td>#<%= t.id %></td>
                            <td><span class="badge badge--<%= t.tipo.toLowerCase() %>"><%= t.tipo %></span></td>
                            <td><%= t.cliente %></td>
                            <td><%= t.descripcion %></td>
                            <td><%= t.fecha %></td>
                            <td class="transaccion-monto">$<%= t.monto?.toLocaleString('es-AR') %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

    </main>
    <%- include('../partials/scripts.ejs') %>
</body>
</html>
