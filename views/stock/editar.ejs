<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar producto</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/sidebar.ejs') %>
    <main id="stock-nuevo">

        <div class="page-header">
            <div>
                <a href="/stock" class="back-link">← Stock</a>
                <h1 class="page-title">Editar producto #<%= producto.id %></h1>
            </div>
        </div>

        <div class="form-card">
            <form action="/stock/editar/<%= producto.id %>" method="POST" class="form-grid">

                <div class="form-group">
                    <label for="producto">Nombre del producto</label>
                    <input type="text" name="producto" id="producto" value="<%= producto.producto %>" required>
                </div>

                <div class="form-group">
                    <label for="precio">Precio unitario ($)</label>
                    <input type="number" name="precio" id="precio" value="<%= producto.precio %>" min="0" required>
                </div>

                <div class="form-group">
                    <label for="stock">Stock disponible</label>
                    <input type="number" name="stock" id="stock" value="<%= producto.stock %>" min="0" required>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary">Guardar cambios</button>
                    <a href="/stock" class="btn-secondary">Cancelar</a>
                </div>

            </form>
        </div>

    </main>
    <script src="/javascript/sidebar.js"></script>
</body>
</html>
