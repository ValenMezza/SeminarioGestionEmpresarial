<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nuevo producto</title>
    <link rel="icon" type="image/jpeg" href="/img/suelosurjpg.jpg">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/sidebar.ejs') %>
    <main id="stock-nuevo">

        <div class="page-header">
            <div>
                <a href="/stock" class="back-link">← Stock</a>
                <h1 class="page-title">Agregar producto</h1>
            </div>
        </div>

        <div class="form-card">
            <form action="/stock/nuevo_stock" method="POST" class="form-grid">

                <div class="form-group">
                    <label for="producto">Nombre del producto</label>
                    <input type="text" name="producto" id="producto" placeholder="Ej: Arena fina">
                </div>

                <div class="form-group">
                    <label for="precio">Precio</label>
                    <input type="number" name="precio" id="precio" min="0" placeholder="0">
                </div>

                <div class="form-group">
                    <label for="stock">Stock inicial</label>
                    <input type="number" name="stock" id="stock" min="0" placeholder="0">
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-primary">Guardar</button>
                    <a href="/stock" class="btn-secondary">Cancelar</a>
                </div>

            </form>
        </div>

    </main>
    <%- include('../partials/scripts.ejs') %>
</body>
</html>
