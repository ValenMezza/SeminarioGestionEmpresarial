<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Editar alquiler</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>

<body>
    <%- include('../partials/sidebar.ejs') %>
        <main id="alquiler-editar">

            <div class="page-header">
                <div>
                    <a href="/alquileres/detalle/<%= contenedor.id %>" class="back-link">← Detalle</a>
                    <h1 class="page-title">Editar contenedor #<%= contenedor.id %>
                    </h1>
                </div>
            </div>

            <div class="form-card">
                <form action="/alquileres/editar/<%= contenedor.id %>" method="POST" class="form-grid">

                    <div class="form-group">
                        <label for="cliente">Cliente</label>
                        <input type="text" name="cliente" id="cliente" value="<%= contenedor.cliente || '' %>">
                    </div>

                    <div class="form-group">
                        <label for="fechaInicio">Fecha de inicio</label>
                        <input type="date" name="fechaInicio" id="fechaInicio"
                            value="<%= contenedor.inicioAlquiler || '' %>">
                    </div>

                    <div class="form-group">
                        <label for="fechaFin">Fecha de fin</label>
                        <input type="date" name="fechaFin" id="fechaFin" value="<%= contenedor.finAlquiler || '' %>">
                    </div>

                    <div class="form-row-2">
                        <div class="form-group">
                            <label for="calle">Calle</label>
                            <input type="text" name="calle" id="calle" value="<%= calle %>">
                        </div>
                        <div class="form-group">
                            <label for="numero">Número</label>
                            <input type="text" name="numero" id="numero" value="<%= numero %>">
                        </div>
                    </div>
                    <button type="button" id="btnBuscarDireccion" class="btn-secondary">
                        Buscar en mapa
                    </button>
                    <p id="msgMapa">
                        Ingresá calle y número para buscar.
                    </p>
                    <div id="mapaEntrega">
                        <iframe id="iframeMapa" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="btn-primary">Guardar cambios</button>
                        <a href="/alquileres" class="btn-secondary">Cancelar</a>
                    </div>

                </form>
            </div>

        </main>
        <%- include('../partials/scripts.ejs') %>
</body>

</html>