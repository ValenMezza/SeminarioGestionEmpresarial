<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Detalle alquiler</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/sidebar.ejs') %>
    <main id="alquiler-detalle">

        <div class="page-header">
            <div>
                <a href="/alquileres" class="back-link">← Alquileres</a>
                <h1 class="page-title">Contenedor #<%= contenedor.id %></h1>
            </div>
            <% if (contenedor.estado === "Alquilado") { %>
                <div style="display:flex; gap:0.75rem;">
                    <a href="/alquileres/editar/<%= contenedor.id %>" class="btn-secondary">Editar</a>
                    <form action="/alquileres/finalizar/<%= contenedor.id %>" method="POST" style="margin:0;">
                        <button type="submit" class="btn-danger">Finalizar alquiler</button>
                    </form>
                </div>
            <% } %>
        </div>

        <div class="detail-card">
            <div class="info-grid">
                <div class="info-row">
                    <span class="info-label">Estado</span>
                    <span class="info-value">
                        <span class="badge badge--<%= contenedor.estado === 'Alquilado' ? 'alquilado' : 'disponible' %>">
                            <%= contenedor.estado %>
                        </span>
                    </span>
                </div>
                <% if (contenedor.estado === "Alquilado") { %>
                    <div class="info-row">
                        <span class="info-label">Cliente</span>
                        <span class="info-value"><%= contenedor.cliente %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Inicio del alquiler</span>
                        <span class="info-value"><%= formatFecha(contenedor.inicioAlquiler) %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Fin del alquiler</span>
                        <span class="info-value"><%= formatFecha(contenedor.finAlquiler) %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Dirección</span>
                        <span class="info-value"><%= contenedor.direccionAlquiler %></span>
                    </div>
                    <div class="info-row">
                        <span class="info-label">Precio alquiler</span>
                        <span class="info-value">$<%= contenedor.precioAlquiler?.toLocaleString('es-AR') %></span>
                    </div>
                <% } %>
            </div>
        </div>

        <% if (contenedor.estado === "Alquilado") { %>
            <div id="mapaEntrega">
                <iframe id="iframeMapa" width="100%" height="350" style="border:0; border-radius:12px;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        <% } %>

    </main>
    <%- include('../partials/scripts.ejs') %>
</body>
</html>
