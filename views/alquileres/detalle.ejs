<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/styles.css">

</head>

<body>
    <%- include('../partials/sidebar.ejs') %>
        <h1>DETALLES</h1>
        <main>
            <h1>detalle por id</h1>
            <% if (contenedor.estado==="Alquilado" ) { %>
                <%= contenedor.id %>
                    <%= contenedor.estado %>
                        <%= contenedor.cliente %>
                            <%= contenedor.finAlquiler %>
                                <%= contenedor.direccionAlquiler %>
                                    <% } else { %>
                                        <%= contenedor.id %>
                                            <%= contenedor.estado %>
                                                <% } %>
        </main>




        <%- include('../partials/scripts.ejs') %>
</body>

</html>