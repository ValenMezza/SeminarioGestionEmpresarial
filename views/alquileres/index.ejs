<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alquileres</title>
    <link rel="icon" type="image/jpeg" href="/img/suelosurjpg.jpg">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/sidebar.ejs') %>
    <main id="mainAlquileres">

        <div class="page-header">
            <h1 class="page-title">Alquileres</h1>
            <a href="/alquileres/nuevo_alquiler" class="btn-primary-green">+ Nuevo alquiler</a>
        </div>

        <!-- Proximos a finalizar (FIFO) -->
        <% if (porFinalizar.length > 0) { %>
        <div class="alquileres-seccion">
            <h2 class="section-title">Proximos a finalizar (≤ 2 dias)</h2>
            <div class="table-wrapper">
                <table class="data-table data-table--warning">
                    <thead>
                        <tr>
                            <th>#Contenedor</th>
                            <th>Cliente</th>
                            <th>Fin</th>
                            <th>Direccion</th>
                            <th>Precio</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% porFinalizar.forEach(c => { %>
                            <tr>
                                <td>#<%= c.id %></td>
                                <td><%= c.cliente %></td>
                                <td><%= formatFecha(c.finAlquiler) %></td>
                                <td><%= c.direccionAlquiler %></td>
                                <td>$<%= c.precioAlquiler?.toLocaleString('es-AR') %></td>
                                <td class="td-acciones">
                                    <a href="/alquileres/detalle/<%= c.id %>" class="btn-secondary btn-sm">Detalle</a>
                                    <a href="/alquileres/nuevo_alquiler?renovar=<%= c.id %>" class="btn-primary btn-sm">Renovar</a>
                                    <form action="/alquileres/finalizar/<%= c.id %>" method="POST" style="display:inline"
                                          onsubmit="return confirm('¿Finalizar alquiler del Contenedor #<%= c.id %>?')">
                                        <button type="submit" class="btn-primary-green btn-sm">Finalizar</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>

        <% if (programados.length > 0) { %>
        <div class="alquileres-seccion">
            <h2 class="section-title">Proximos a iniciar (programados)</h2>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#Alquiler</th>
                            <th>#Contenedor</th>
                            <th>Cliente</th>
                            <th>Inicio</th>
                            <th>Fin</th>
                            <th>Direccion</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% programados.forEach(a => { %>
                            <tr>
                                <td>#<%= a.id %></td>
                                <td>#<%= a.contenedorId %></td>
                                <td><%= a.clienteNombre %></td>
                                <td><%= formatFecha(a.inicioAlquiler) %></td>
                                <td><%= formatFecha(a.finAlquiler) %></td>
                                <td><%= a.direccionAlquiler %></td>
                                <td><span class="badge badge--alquilado">Programado</span></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>

        <%
            // divido los "Alquilado" en: ya iniciados vs reservados con inicio futuro
            const hoyStr = new Date().toISOString().slice(0, 10);
            const alquiladosTodos = contenedores.filter(c => c.estado === "Alquilado");
            const reservadosFuturos = alquiladosTodos.filter(c => c.inicioAlquiler && c.inicioAlquiler > hoyStr);
            const alquilados = alquiladosTodos.filter(c => !c.inicioAlquiler || c.inicioAlquiler <= hoyStr);
        %>

        <% if (reservadosFuturos.length > 0) { %>
        <div class="alquileres-seccion">
            <h2 class="section-title">Reservados proximos a iniciar</h2>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#Contenedor</th>
                            <th>Cliente</th>
                            <th>Inicio</th>
                            <th>Fin</th>
                            <th>Direccion</th>
                            <th>Precio</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% reservadosFuturos.forEach(c => { %>
                            <tr>
                                <td>#<%= c.id %></td>
                                <td><%= c.cliente %></td>
                                <td><%= formatFecha(c.inicioAlquiler) %></td>
                                <td><%= formatFecha(c.finAlquiler) %></td>
                                <td><%= c.direccionAlquiler %></td>
                                <td>$<%= c.precioAlquiler?.toLocaleString('es-AR') %></td>
                                <td class="td-acciones">
                                    <a href="/alquileres/detalle/<%= c.id %>" class="btn-secondary btn-sm">Detalle</a>
                                    <a href="/alquileres/editar/<%= c.id %>" class="btn-secondary-yellow btn-sm">Editar</a>
                                    <form action="/alquileres/finalizar/<%= c.id %>" method="POST" style="display:inline"
                                            onsubmit="return confirm('¿Cancelar reserva del Contenedor #<%= c.id %>?')">
                                        <button type="submit" class="btn-primary-green btn-sm">Cancelar</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
        <% } %>

        <div class="alquileres-seccion">
            <h2 class="section-title">Alquileres activos</h2>
            <div class="table-wrapper">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#Contenedor</th>
                            <th>Cliente</th>
                            <th>Inicio</th>
                            <th>Fin</th>
                            <th>Fin próx. alquiler</th>
                            <th>Direccion</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (alquilados.length === 0) { %>
                            <tr>
                                <td colspan="7" class="td-vacia">No hay alquileres activos</td>
                            </tr>
                        <% } %>
                        <% alquilados.forEach(c => { %>
                            <tr>
                                <td>#<%= c.id %></td>
                                <td><%= c.cliente %></td>
                                <td><%= formatFecha(c.inicioAlquiler) %></td>
                                <td><%= formatFecha(c.finAlquiler) %></td>
                                <td>
                                    <% if (finProximoPorContenedor[c.id]) { %>
                                        <span class="badge badge--alquilado"><%= formatFecha(finProximoPorContenedor[c.id]) %></span>
                                    <% } else { %>
                                        —
                                    <% } %>
                                </td>
                                <td><%= c.direccionAlquiler %></td>
                                <td class="td-acciones">
                                    <a href="/alquileres/detalle/<%= c.id %>" class="btn-secondary btn-sm">Detalle</a>
                                    <a href="/alquileres/editar/<%= c.id %>" class="btn-secondary-yellow btn-sm">Editar</a>
                                    <% if (!finProximoPorContenedor[c.id]) { %>
                                        <a href="/alquileres/nuevo_alquiler?renovar=<%= c.id %>" class="btn-primary btn-sm">Renovar</a>
                                    <% } %>
                                    <form action="/alquileres/finalizar/<%= c.id %>" method="POST" style="display:inline"
                                            onsubmit="return confirm('¿Finalizar alquiler del Contenedor #<%= c.id %>?')">
                                        <button type="submit" class="btn-primary-green btn-sm">Finalizar</button>
                                    </form>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

    </main>
    <%- include('../partials/scripts.ejs') %>
</body>
</html>
