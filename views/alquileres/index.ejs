<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alquileres</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('../partials/sidebar.ejs') %>
    <main id="mainAlquileres">

        <div class="page-header">
            <h1 class="page-title">Alquileres</h1>
            <a href="/alquileres/nuevo_alquiler" class="btn-primary">+ Nuevo alquiler</a>
        </div>

        <div class="table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>#ID</th>
                        <th>Cliente</th>
                        <th>Inicio</th>
                        <th>Fin</th>
                        <th>Dirección</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <% const alquilados = contenedores.filter(c => c.estado === "Alquilado"); %>
                    <% if (alquilados.length === 0) { %>
                        <tr>
                            <td colspan="6" class="td-vacia">
                                No hay alquileres activos
                            </td>
                        </tr>
                    <% } %>
                    <% alquilados.forEach(c => { %>
                        <tr>
                            <td>#<%= c.id %></td>
                            <td><%= c.cliente %></td>
                            <td><%= formatFecha(c.inicioAlquiler) %></td>
                            <td><%= formatFecha(c.finAlquiler) %></td>
                            <td><%= c.direccionAlquiler %></td>
                            <td class="td-acciones">
                                <a href="/alquileres/detalle/<%= c.id %>" class="btn-secondary">Ver detalle</a>
                                <a href="/alquileres/editar/<%= c.id %>" class="btn-secondary">Editar</a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

    </main>
    <%- include('../partials/scripts.ejs') %>
</body>
</html>
