<!-- Modal: Finalizar Venta - Cantera -->
<div id="modal-cantera" class="modal-overlay" style="display:none">
    <div class="modal-box modal-box--lg">
        <div class="modal-header">
            <h2 class="modal-title">Finalizar venta — Cantera</h2>
            <button type="button" class="modal-close" id="cerrarModalCantera">✕</button>
        </div>

        <form action="/ventas/finalizar-cantera" method="POST" class="form-grid" id="formCantera">
            <input type="hidden" name="items" id="itemsCantera">

            <!-- Tipo de cliente -->
            <div class="form-group">
                <label>Tipo de cliente</label>
                <div class="radio-group">
                    <label class="radio-option">
                        <input type="radio" name="tipoCliente" value="existente" checked id="tipoExistente">
                        <span>Cliente existente</span>
                    </label>
                    <label class="radio-option">
                        <input type="radio" name="tipoCliente" value="particular" id="tipoParticular">
                        <span>Particular</span>
                    </label>
                </div>
            </div>

            <!-- Selector cliente existente -->
            <div class="form-group" id="grupoClienteExistente">
                <label for="clienteExistente">Seleccionar cliente</label>
                <select name="clienteExistente" id="clienteExistente">
                    <option value="">— Seleccioná un cliente —</option>
                    <% clientes.forEach(c => { %>
                        <option value="<%= c.nombre %>"><%= c.nombre %> (<%= c.telefono || 'sin tel.' %>)</option>
                    <% }) %>
                </select>
            </div>

            <!-- Datos de cliente particular -->
            <div id="grupoParticular" style="display:none">
                <div class="form-group">
                    <label for="nombreParticular">Nombre del cliente</label>
                    <input type="text" name="nombreParticular" id="nombreParticular" placeholder="Ej: Carlos Gómez">
                </div>
                <div class="form-group" style="margin-top:0.75rem">
                    <label for="telefonoParticular">Teléfono (opcional)</label>
                    <input type="text" name="telefonoParticular" id="telefonoParticular" placeholder="Ej: 351 000 0000">
                </div>
            </div>

            <!-- Resumen del carrito -->
            <div class="form-group">
                <label>Resumen del pedido</label>
                <div id="resumenCantera" class="resumen-box"></div>
            </div>

            <div class="modal-actions">
                <button type="submit" class="btn-finalizar">Confirmar venta</button>
                <button type="button" class="btn-secondary" id="cancelarModalCantera">Cancelar</button>
            </div>
        </form>
    </div>
</div>
