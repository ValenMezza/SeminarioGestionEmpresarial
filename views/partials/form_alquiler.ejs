<form action="/alquileres/crear" method="POST" class="alquiler-form">

    <%# ── Sección: Cliente ── %>
    <div class="form-section">
        <h3 class="form-section__title">Cliente</h3>

        <div class="form-group">
            <label for="cliente">Cliente existente</label>
            <select name="cliente" id="cliente">
                <option value="">— Seleccionar cliente —</option>
                <% clientes.forEach(c => { %>
                    <option value="<%= c.nombre %>"><%= c.nombre %></option>
                <% }) %>
            </select>
        </div>

        <div class="toggle-row">
            <input type="checkbox" name="nuevoCliente" id="nuevoCliente">
            <label for="nuevoCliente">Crear nuevo cliente</label>
        </div>

        <div id="creacionCliente" class="form-subsection">
            <p class="form-hint">La creación de un nuevo cliente impactará en el sistema para futuras ventas.</p>
            <div class="form-group">
                <label for="nameNuevoCliente">Nombre</label>
                <input type="text" name="nombreNuevoCliente" id="nameNuevoCliente" placeholder="Nombre completo">
            </div>
            <div class="form-group">
                <label for="telefonoNuevoCliente">Teléfono</label>
                <input type="text" name="telefonoNuevoCliente" id="telefonoNuevoCliente" placeholder="351 000 0000">
            </div>
        </div>
    </div>

    <%# ── Sección: Contenedor ── %>
    <div class="form-section">
        <h3 class="form-section__title">Contenedor</h3>

        <div class="form-group">
            <label for="selectDisponibles">Contenedor disponible</label>
            <select name="contenedor" id="selectDisponibles">
                <% contenedorlibre.forEach(c => { %>
                    <option value="<%= c.id %>">Contenedor #<%= c.id %></option>
                <% }) %>
            </select>
        </div>

        <div class="toggle-row">
            <input type="checkbox" name="contenedorPorFinalizarCheck" id="contenedorPorFinalizar">
            <label for="contenedorPorFinalizar">Ver contenedores por finalizar (vencen en ≤ 2 días)</label>
        </div>

        <div class="form-group" id="grupoPorFinalizar">
            <label>Contenedor por finalizar</label>
            <select name="contenedor" id="selectPorFinalizar" disabled>
                <% contenedoresPorFinalizar.forEach(c => { %>
                    <option value="<%= c.id %>" data-fin="<%= c.finAlquiler %>">
                        Contenedor #<%= c.id %> — vence <%= c.finAlquiler %>
                    </option>
                <% }) %>
                <% if (contenedoresPorFinalizar.length === 0) { %>
                    <option disabled>No hay contenedores por finalizar</option>
                <% } %>
            </select>
        </div>
    </div>

    <div class="form-section">
        <h3 class="form-section__title">Período</h3>
        <p class="form-hint">El alquiler debe ser mínimo 4 días y máximo 9 días.</p>

        <div class="form-row-2">
            <div class="form-group">
                <label for="fechaInicio">Fecha de inicio</label>
                <input type="date" name="fechaInicio" id="fechaInicio">
            </div>
            <div class="form-group">
                <label for="fechaFin">Fecha de fin</label>
                <input type="date" name="fechaFin" id="fechaFin">
            </div>
        </div>
    </div>

    <div class="form-section">
        <h3 class="form-section__title">Dirección de entrega</h3>

        <div class="form-row-2">
            <div class="form-group">
                <label for="calle">Calle</label>
                <input type="text" name="calle" id="calle" placeholder="Av. Siempre Viva">
            </div>
            <div class="form-group">
                <label for="numero">Número</label>
                <input type="text" name="numero" id="numero" placeholder="123">
            </div>
        </div>

        <button type="button" id="btnBuscarDireccion" class="btn-secondary">
            Buscar en mapa
        </button>
        <p id="msgMapa">
            Ingresá calle y número para buscar.
        </p>
        <div id="mapaEntrega">
            <iframe id="iframeMapa" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
    </div>

    <div class="form-section">
        <h3 class="form-section__title">Método de pago</h3>

        <div class="form-group">
            <label for="metodoPago">Método</label>
            <select name="metodoPago" id="metodoPago">
                <option value="efectivo">Efectivo</option>
                <option value="transferencia">Transferencia bancaria</option>
            </select>
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn-primary">Confirmar alquiler</button>
        <button type="reset" class="btn-secondary">Limpiar</button>
    </div>

</form>
