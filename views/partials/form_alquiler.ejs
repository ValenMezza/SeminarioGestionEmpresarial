<form action="/alquileres/crear" method="POST">
    <div>
        <label for="cliente">Cliente</label>
        <input type="text" name="cliente" id="cliente">
        <label for="nuevoCliente">Crear nuevo cliente</label>
        <input type="checkbox" name="nuevoCliente" id="nuevoCliente">
    </div>
    <div id="creacionCliente" style="display:none">
        <h3>Crear nuevo cliente</h3>
        <p class="leyenasForm">La creación de un nuevo cliente impactará en el sistema para futuras ventas.</p>
        <label for="nameNuevoCliente">Nombre:</label>
        <input type="text" name="nombreNuevoCliente" id="nameNuevoCliente">
        <label for="telefonoNuevoCliente">Teléfono:</label>
        <input type="text" name="telefonoNuevoCliente" id="telefonoNuevoCliente">

    </div>
    <div id="datosAlquiler">
        <h3>Datos del alquiler</h3>
        <label for="contenedor">Contenedor asignado:</label>
        <select name="contenedor" id="selectDisponibles">
            <% contenedorlibre.forEach(c => { %>
                <option value="<%= c.id %>">Contenedor #<%= c.id %></option>
            <% }) %>
        </select>

        <label for="contenedorPorFinalizar">Ver contenedores por finalizar (vencen en ≤2 días)</label>
        <input type="checkbox" name="contenedorPorFinalizarCheck" id="contenedorPorFinalizar">

        <select name="contenedor" id="selectPorFinalizar" style="display:none" disabled>
            <% contenedoresPorFinalizar.forEach(c => { %>
                <option value="<%= c.id %>" data-fin="<%= c.finAlquiler %>">Contenedor #<%= c.id %> — vence <%= c.finAlquiler %></option>
            <% }) %>
            <% if (contenedoresPorFinalizar.length === 0) { %>
                <option disabled>No hay contenedores por finalizar</option>
            <% } %>
        </select>

        <p class="leyenasForm">El alquiler debe ser mínimo 4 días y máximo 9 días</p>
        <label for="fechaInicio">Fecha de inicio:</label>
        <input type="date" name="fechaInicio" id="fechaInicio">
        <label for="fechaFin">Fecha de fin:</label>
        <input type="date" name="fechaFin" id="fechaFin">
        
        <div id="datosDireccion">
            <h3>Datos de la dirección</h3>
            <label for="calle">Calle:</label>
            <input type="text" name="calle" id="calle">
            <label for="numero">Número:</label>
            <input type="text" name="numero" id="numero">
            <button type="button" id="btnBuscarDireccion">Buscar dirección</button>
            <p id="msgMapa" style="display:none; color:red;">Ingresá calle y número para buscar.</p>
            <div id="mapaEntrega" style="display:none;">
                <iframe id="iframeMapa" width="100%" height="350" style="border:0;" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>

    </div>
    <div>
        <h3>Método de pago</h3>
        <label for="metodoPago">Selecciona un método de pago:</label>
        <select name="metodoPago" id="metodoPago">
            <option value="efectivo">Efectivo</option>
            <option value="tarjeta">Tarjeta de crédito/débito</option>
            <option value="transferencia">Transferencia bancaria</option>
        </select>
    </div>
    <button type="submit">Crear alquiler</button>
    <button type="reset">Cancelar</button>

</form>